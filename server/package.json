{
  "name": "finance-tracker-server",
  "version": "1.0.0",
  "private": true,
  "description": "Finance Tracker — Express + MongoDB API",
  "engines": { "node": ">=18" },
  "scripts": {
    "dev":           "nodemon --watch src --watch .env src/index.js",
    "start":         "node src/index.js",
    "test":          "NODE_ENV=test jest --runInBand --forceExit",
    "test:coverage": "NODE_ENV=test jest --runInBand --forceExit --coverage"
  },
  "dependencies": {
    "bcryptjs":                "^3.0.2",
    "cookie-parser":           "^1.4.7",
    "cors":                    "^2.8.5",
    "dotenv":                  "^16.5.0",
    "express":                 "^5.1.0",
    "express-rate-limit":      "^7.5.0",
    "helmet":                  "^8.1.0",
    "jsonwebtoken":            "^9.0.2",
    "mongoose":                "^9.6.1",
    "morgan":                  "^1.10.0",
    "multer":                  "^2.1.1",
    "passport":                "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "zod":                     "^3.24.3"
  },
  "devDependencies": {
    "jest":                  "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon":               "^3.1.10",
    "supertest":             "^7.1.0"
  },
  "jest": {
    "testEnvironment":     "node",
    "setupFilesAfterEnv": ["./tests/setup.js"],
    "testTimeout":         30000,
    "testMatch":           ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"],
    "coveragePathIgnorePatterns": ["/node_modules/", "src/index.js"]
  }
}
